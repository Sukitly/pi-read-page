{
  "name": "pi-read-page",
  "version": "0.1.0",
  "description": "Read webpages through a local browser and return Markdown for Pi coding agent.",
  "type": "module",
  "license": "MIT",
  "author": "Sukitly",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sukitly/pi-read-page.git"
  },
  "homepage": "https://github.com/Sukitly/pi-read-page#readme",
  "bugs": {
    "url": "https://github.com/Sukitly/pi-read-page/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "read-page",
    "browser",
    "markdown"
  ],
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-read-page.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "integration": "tsx scripts/integration-read-page.ts",
    "lint": "bun run typecheck && bunx --bun @biomejs/biome check --error-on-warnings --write ."
  },
  "dependencies": {
    "defuddle": "^0.19.1",
    "linkedom": "^0.18.12",
    "playwright-core": "^1.61.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typebox": "1.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
